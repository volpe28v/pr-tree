{
  "name": "pr-tree-app",
  "version": "1.0.0",
  "description": "GitHub PR Tree Viewer",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc && node esbuild.config.mjs",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron . --devtools",
    "package": "npm run build && npx electron-packager . PRTree --platform=darwin --arch=arm64 --out=release --overwrite && cp -r 'release/PRTree-darwin-arm64/PRTree.app' /Applications/"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
